# /etc/duitku/passwords.toml
#
# List of PDF passwords to try in order. First successful decrypt wins.
# Use this for IC last-6, full IC, DOB DDMMYY, etc. — anything any of
# your bank PDFs is locked with.
#
# Live in a ConfigMap so kubectl edit is the routine maintenance verb.
# The duitku binary redacts these strings from error sidecars and logs
# regardless of whether they're "secret enough" to live in a Secret.

passwords = [
  # "780101",
  # "010178",
]
